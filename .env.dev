# Development profile overrides
API_DEV_PORT=8011
FRONTEND_DEV_PORT=9098

# Frontend(dev) -> API(dev)
NGINX_API_PROXY_PASS_DEV=http://api-dev:8000/api/

# Enable legacy compatibility routes for old dev bundle behavior
API_ENABLE_LEGACY_COMPAT_ROUTES_DEV=true

# 관련 문서 종류 제안 (cross-type expansion)
RAG_RELATION_EXPAND_ENABLED=true
