PYTHONPATH="/home/hskim/work/llm-agent"

# LLM (text) server
MODEL_LLM=openai/gpt-oss-20b
LLM_PORT=8003
VLLM_CUDA_DEVICES=0,1
VLLM_CUDA_DEVICE=0
VLLM_CUDA_DEVICE1=1
VLLM_TP_SIZE=2
VLLM_MAX_MODEL_LEN=32768
VLLM_GPU_MEM_UTIL=0.6
VLLM_SHM_SIZE=8g
VLLM_TIMEOUT=600

# VLM (vision) server (optional, profile with-vlm)
MODEL_VLM=Qwen/Qwen3-VL-30B-A3B-Instruct
VLM_PORT=8004
VLM_CUDA_DEVICES=0,1
VLM_TP_SIZE=2
VLM_MAX_MODEL_LEN=16384
VLM_GPU_MEM_UTIL=0.9
VLM_SHM_SIZE=8g

ES_DATA_PATH=/home/llm-share/es_data

API_PORT=8001
API_DEV_PORT=8011
ES_PORT=8002
TEI_PORT=8080
FRONTEND_PORT=9097
FRONTEND_DEV_PORT=9098

# Frontend nginx -> API upstream (prod 기본값: compose 내부 api 서비스)
# dev/prod 분리 시 dev 스택에서 별도 값 사용 (예: http://rag-api-dev:8000/api/)
NGINX_API_PROXY_PASS=http://api:8000/api/

# Legacy FE 호환 라우트 (/api/search/chat-pipeline 등)
# prod(false) / dev(true)로 분리 운영 권장
API_ENABLE_LEGACY_COMPAT_ROUTES=false
API_ENABLE_LEGACY_COMPAT_ROUTES_DEV=true

# Frontend nginx -> API upstream (dev 전용)
NGINX_API_PROXY_PASS_DEV=http://api-dev:8000/api/

# LLM Client settings (for backend code)
# Docker network: use service name + internal port (not host port)
# vllm service listens on internal port 8000
# For local execution outside Docker, use host IP and mapped port
VLLM_BASE_URL=http://10.10.100.45:8003
VLLM_MODEL_NAME=${MODEL_LLM}
VLLM_TIMEOUT=600
VLLM_MAX_MODEL_LEN=32768
RAG_LLM_METHOD=ollama
RAG_PROMPT_SPEC_VERSION=v2
OLLAMA_BASE_URL=http://host.docker.internal:11435
# Ollama model names can differ from vLLM/OpenAI model ids.
OLLAMA_MODEL_NAME=gpt-oss:120b
OLLAMA_TIMEOUT=600
OLLAMA_MAX_TOKENS=30000
OLLAMA_TEMPERATURE=0.7

# VLM Client settings (for vision model)
# Docker network: vlm service listens on internal port 8000
VLM_CLIENT_BASE_URL=http://localhost:8004/v1
VLM_CLIENT_MODEL=${MODEL_VLM}
VLM_CLIENT_TIMEOUT=600
VLM_CLIENT_MAX_TOKENS=2048
VLM_CLIENT_TEMPERATURE=0.0

# Elasticsearch settings
# Docker network: use service name + internal port (9200)
SEARCH_ES_HOST=http://localhost:8002
SEARCH_ES_ENV=dev
SEARCH_ES_INDEX_PREFIX=rag_chunks
SEARCH_ES_EMBEDDING_DIMS=1024
SEARCH_BACKEND=es
SEARCH_CHUNK_VERSION=v3
SEARCH_V3_EMBED_INDEX=chunk_v3_embed_bge_m3_v1
RAG_EMBEDDING_METHOD=bge_m3
RAG_RAPTOR_ENABLED=true
RAG_RERANK_ENABLED=true

# MinIO settings (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=doc-images
MINIO_ENDPOINT=http://minio:9000
MINIO_SECURE=false

